PORT=3000
NODE_ENV=development
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1h
BOOTSTRAP_ADMIN_EMAIL=replace_with_admin_email
BOOTSTRAP_ADMIN_PASSWORD=replace_with_admin_password
POSTGRES_USER=replace_with_postgres_user
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_DB=replace_with_postgres_db
DATABASE_URL=postgresql://replace_with_postgres_user:replace_with_postgres_password@localhost:5432/replace_with_postgres_db?schema=public
INFLUX_URL=http://localhost:8086
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=replace_with_influx_admin_username
DOCKER_INFLUXDB_INIT_PASSWORD=replace_with_influx_admin_password
INFLUX_TOKEN=replace_with_influx_admin_token
INFLUX_ORG=replace_with_influx_org
INFLUX_BUCKET=replace_with_influx_bucket
MQTT_URL=mqtts://localhost:8883
MQTT_USERNAME=replace_with_mqtt_username
MQTT_PASSWORD=replace_with_mqtt_password
MQTT_INGEST_TOPIC=factory/sensors/+/telemetry
MQTT_PUBLISH_TOPIC_TEMPLATE=factory/sensors/{sensor_id}/processed
MQTT_PUBLISH_QOS=1
MQTT_PUBLISH_RETAIN=true
MQTT_TLS_REJECT_UNAUTHORIZED=true
MQTT_TLS_CA_PATH=./docker/mosquitto/certs/ca.crt